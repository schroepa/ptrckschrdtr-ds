---
/**
 * ptrckschrdtr-ds — Button (Astro)
 *
 * Props:
 *   variant  — 'primary' | 'secondary' | 'ghost' | 'danger'  (default: 'primary')
 *   size     — 'sm' | 'md' | 'lg'                            (default: 'md')
 *   href     — string  → renders as <a>, otherwise <button>
 *   type     — 'button' | 'submit' | 'reset'                 (default: 'button')
 *   disabled — boolean
 *   loading  — boolean
 *   full     — boolean  → full width
 *   icon     — boolean  → icon-only (square, no label padding)
 *   class    — additional CSS classes
 */

import './button.css'

interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'danger'
  size?: 'sm' | 'md' | 'lg'
  href?: string
  type?: 'button' | 'submit' | 'reset'
  disabled?: boolean
  loading?: boolean
  full?: boolean
  icon?: boolean
  class?: string
  [key: string]: unknown
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  loading = false,
  full = false,
  icon = false,
  class: className,
  ...rest
} = Astro.props

const Tag = href ? 'a' : 'button'

const classes = [
  'btn',
  `btn--${variant}`,
  `btn--${size}`,
  icon  && 'btn--icon',
  full  && 'btn--full',
  loading && 'btn--loading',
  className,
].filter(Boolean).join(' ')
---

<Tag
  class={classes}
  href={href}
  type={!href ? type : undefined}
  disabled={!href && disabled ? true : undefined}
  aria-disabled={disabled || loading ? 'true' : undefined}
  {...rest}
>
  {loading && (
    <svg
      class="btn__spinner"
      width="16"
      height="16"
      viewBox="0 0 16 16"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2" stroke-dasharray="28" stroke-dashoffset="10" style="transform-origin:center;animation:btn-spin 0.7s linear infinite" />
    </svg>
  )}
  <slot />
</Tag>

<style is:global>
  @keyframes btn-spin {
    to { transform: rotate(360deg); }
  }
</style>
